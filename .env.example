# nice-deck graphic generation (scripts/image.py)
# Copy to `.env` and fill in. `.env` is gitignored; never commit real values.
#
# image.py talks to an Azure OpenAI image deployment such as gpt-image-2
# using an Entra ID (AAD) token from the Azure CLI — no API keys required.

# Your Azure OpenAI resource endpoint (required)
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com

# The image model deployment name on that resource (required)
AZURE_OPENAI_DEPLOYMENT=gpt-image-2

# Optional: pin an api-version. If unset, image.py tries a sensible list.
# AZURE_OPENAI_API_VERSION=2025-04-01-preview

# Optional: subscription for `az account get-access-token` (if you have many)
# AZURE_SUBSCRIPTION_ID=
